# Copy this file to `.env` and adjust values as needed.
# These variables provide default values for the AES and RSA CLIs.
# Explicit CLI arguments still take precedence over environment variables.

# AES configuration
# AES key text. Must encode to 16, 24, or 32 bytes.
AES_KEY=1234567891234567
# Plaintext input used by `aes/aes-encrypt.py` when no input path is provided.
AES_INPUT_PATH=aes/file_to_encrypt
# Shared encrypted file path used by AES encrypt output and AES decrypt input.
AES_ENCRYPTED_PATH=aes/encrypted.aes
# Plaintext output used by `aes/aes-decrypt.py` when --output is not provided.
AES_DECRYPTED_PATH=aes/decrypted_file

# RSA configuration
# Public key path used by `rsa/rsa_cli.py`.
RSA_PUBLIC_KEY_PATH=rsa/public_key.txt
# Private key path used by `rsa/rsa_cli.py`.
RSA_PRIVATE_KEY_PATH=rsa/private_key.txt
# Signature file path used by the RSA sign and verify commands.
RSA_SIGNATURE_PATH=rsa/signature
# Ciphertext file path used by the RSA encrypt and decrypt commands.
RSA_ENCRYPTED_PATH=rsa/encrypted_message.bin
# RSA key size in bits used by `generate-keys`.
RSA_KEY_BITS=2048
# Hash algorithm used by the RSA sign command.
RSA_HASH_METHOD=SHA-256
